# ============================================================
#  YCONN – Linux Server .env
#  Kopieren nach: /opt/yconn/orchestrator/.env
# ============================================================

APP_ENV=prod
LOG_LEVEL=WARNING

# ── Datenbank: PostgreSQL (Linux-Server) ────────────────────
# SQLite (bisherig):
# DATABASE_URL=sqlite:///./orchestrator.db
#
# PostgreSQL (neu):
DATABASE_URL=postgresql://yconn_app:YconnDB#2026!@localhost:5432/yconn

# ── Bridge-URL: Windows-PC im Netzwerk ──────────────────────
# Die Bridge läuft weiterhin auf dem Windows-PC mit SAP GUI!
BRIDGE_URL=http://192.168.1.XX:8765   # <- Windows-PC IP eintragen

# ── Orchestrator ────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8000
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_RELOAD=0

# ── Worker ──────────────────────────────────────────────────
ROBOT_ID=AP
WORKER_ID=worker-linux-01
POLL_INTERVAL=5
