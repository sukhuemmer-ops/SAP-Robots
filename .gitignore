# Virtuelle Umgebungen
worker/.venv/
orchestrator/.venv/

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Sensible Konfiguration – aktive Env-Dateien (nie committen!)
worker/.env
worker/.env.dev
worker/.env.test
worker/.env.prod
worker/.env.backup
orchestrator/.env
orchestrator/.env.dev
orchestrator/.env.test
orchestrator/.env.prod
orchestrator/.env.backup

# Beispiel-Dateien dürfen im Repo sein (kein !*.env.example nötig)
# *.env.example → bereits nicht in der Ignore-Liste → wird getrackt

# Logs
*.log
worker/dev_rfc.log

# Datenbank
orchestrator/*.db
orchestrator/*.sqlite3

# Reports / Ausgaben
worker/reports/
invoices/
rechnungen/

# Temporäre Dateien
*.tmp
*.bak
~$*

# Windows
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/

# Test/Diagnose Batch
Bridge Test.bat
update_invoice_319.bat
