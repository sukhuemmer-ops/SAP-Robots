# YCONN Finance-Assistent – Beispiel-Konfiguration
# Besser: python env_switch.py [dev|test|prod] verwenden.
#
# SAP-Verbindungsregel:
#   APP DEV   → SAP SEQ  172.28.189.11  (Quality Assurance)
#   APP TEST  → SAP SEQ  172.28.189.11  (Quality Assurance)
#   APP PROD  → SAP SEP  172.28.189.8   (Produktivsystem)

APP_ENV=prod
ROBOT_ID=AP
WORKER_ID=worker-ap-vm01
ORCHESTRATOR_URL=http://localhost:8000
POLL_INTERVAL=5

# SAP-Verbindung
SAP_MOCK=0
SAP_ASHOST=172.28.189.8
SAP_SYSNR=06
SAP_CLIENT=600
SAP_USER=RFC_COFACE
SAP_PASSWORD=
SAP_LANG=DE

# SAP GUI Scripting
SAP_GUI_CONNECTION=SEP Catensys Production
SAP_GUI_CONNECTION_SEP=SEP Catensys Production
SAP_GUI_CONNECTION_SEQ=SEQ Catensys Quality Assurance

# Direkt-DB (Sybase ASE)
SAP_DB_DRIVER=Adaptive Server Enterprise
SAP_DB_HOST=172.28.189.8
SAP_DB_PORT=4901
SAP_DB_NAME=SEP
SAP_DB_USER=readonly_dev
SAP_DB_PASSWORD=
SAP_DB_SCHEMA=SEP.SAPSR3

# Claude API
ANTHROPIC_API_KEY=
